{
  "DatabaseProvider": "MongoDB",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=pbmsystem.db",
    "MongoConnection": "mongodb://localhost:27017"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_A_STRONG_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "PBMSystem",
    "Audience": "PBMSystemUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "SmtpSettings": {
    "Host": "sandbox.smtp.mailtrap.io",
    "Port": 587,
    "Username": "REPLACE_WITH_MAILTRAP_USERNAME",
    "Password": "REPLACE_WITH_MAILTRAP_PASSWORD",
    "FromAddress": "no-reply@pbmsystem.dev",
    "FromName": "PBMSystem"
  },
  "AllowedOrigins": [
    "http://localhost:3000"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}